# Скопируйте этот файл в .env и заполните значения
# cp .env.example .env

# ── Nextcloud ──────────────────────────────────────────────────────────
NEXTCLOUD_HOST=https://your-nextcloud.example.com
NEXTCLOUD_USERNAME=your_username
NEXTCLOUD_PASSWORD=your_app_token
# Путь WebDAV: обычно /remote.php/dav/files/USERNAME/
NEXTCLOUD_ROOT=/remote.php/dav/files/

# ── Amazon S3 / MinIO / Yandex Object Storage ─────────────────────────
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_DEFAULT_REGION=ru-central1
S3_BUCKET_NAME=your-bucket-name
# Для не-AWS хранилищ (Yandex, MinIO):
# S3_ENDPOINT_URL=https://storage.yandexcloud.net

# ── HuggingFace (нужен для pyannote.audio) ────────────────────────────
# Получите токен: https://huggingface.co/settings/tokens
# Примите условия: https://huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN=hf_your_token_here

# ── Прочее ────────────────────────────────────────────────────────────
# Директория для кеша моделей (по умолчанию ~/.cache/huggingface)
# HF_HOME=/path/to/your/model/cache
